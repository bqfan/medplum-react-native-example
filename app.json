        "backgroundColor": "#ffffff"
      },
      "package": "com.bqfan.medplumreactnativetest"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "6d58e5b4-2955-4d73-8716-9fb9f7ea19a6"
      }
    }
  }
